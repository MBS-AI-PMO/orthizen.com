<!doctype html>
{% assign locale_rtl = 'ar,fa,he,ks,ps,sd,ur,' %}
{% assign current_locale = localization.language.iso_code | append: ',' %}
<html
  {% if locale_rtl contains current_locale %}
    dir='rtl'
  {% else %}
    dir='ltr'
  {% endif %}
  class='no-js'
  lang='{{ request.locale.iso_code }}'
  xo-money-format='{{ shop.money_format | escape }}'
  xo-money-with-currency-format='{{ shop.money_with_currency_format | escape }}'
>
  <head>
    <meta charset='utf-8'>
    <meta http-equiv='X-UA-Compatible' content='IE=edge'>
    <meta name='viewport' content='width=device-width,initial-scale=1'>
    <meta name='theme-color' content=''>
    <link rel='canonical' href='{{ canonical_url }}'>
    {% render 'preconnect' %}

    {% render 'xotiny-theme' %}

    {%- if settings.favicon != blank -%}
      <link
        rel='icon'
        type='image/png'
        href='{{ settings.favicon | image_url: width: 32, height: 32 }}'
      >
    {%- endif -%}

    {% render 'page-title' %}

    {% if page_description %}
      <meta name='description' content='{{ page_description | escape }}'>
    {% endif %}

    {% render 'meta-tags' %}

    {{ content_for_header }}
    {% render 'settings-adapter' %}

    {{ 'xo-webcomponents.min.css' | asset_url | stylesheet_tag }}
    {{ 'main.min.css' | asset_url | stylesheet_tag }}

    {%- comment -%} Custom font loading {%- endcomment -%}
    {%- if settings.custom_font_url_1 != blank -%}
      <link rel='stylesheet' href='{{ settings.custom_font_url_1 }}'>
    {%- endif -%}
    {%- if settings.custom_font_url_2 != blank -%}
      <link rel='stylesheet' href='{{ settings.custom_font_url_2 }}'>
    {%- endif -%}

    {%- comment -%} Resolve custom font family names {%- endcomment -%}
    {%- assign price_font = settings.price_font_family | default: 'inherit' -%}
    {%- if settings.price_font_family == 'custom_1' -%}
      {%- assign price_font = settings.custom_font_name_1 | default: 'inherit' -%}
      {%- unless price_font == 'inherit' -%}{%- assign price_font = price_font | prepend: "'" | append: "', sans-serif" -%}{%- endunless -%}
    {%- elsif settings.price_font_family == 'custom_2' -%}
      {%- assign price_font = settings.custom_font_name_2 | default: 'inherit' -%}
      {%- unless price_font == 'inherit' -%}{%- assign price_font = price_font | prepend: "'" | append: "', sans-serif" -%}{%- endunless -%}
    {%- endif -%}
    {%- assign btn_font = settings.button_font_family | default: 'inherit' -%}
    {%- if settings.button_font_family == 'custom_1' -%}
      {%- assign btn_font = settings.custom_font_name_1 | default: 'inherit' -%}
      {%- unless btn_font == 'inherit' -%}{%- assign btn_font = btn_font | prepend: "'" | append: "', sans-serif" -%}{%- endunless -%}
    {%- elsif settings.button_font_family == 'custom_2' -%}
      {%- assign btn_font = settings.custom_font_name_2 | default: 'inherit' -%}
      {%- unless btn_font == 'inherit' -%}{%- assign btn_font = btn_font | prepend: "'" | append: "', sans-serif" -%}{%- endunless -%}
    {%- endif -%}

    {%- comment -%} Orthizen brand overrides — survives main.min.css regeneration {%- endcomment -%}
    <style>
      /* Price colors & typography */
      .xo-price__item--accent{color:{{ settings.sale_price_color | default: '#1eb014' }}!important;font-weight:{{ settings.sale_price_weight | default: '700' }}!important;font-size:{{ settings.sale_price_size | default: 22 }}px!important;font-family:{{ price_font }}!important}
      .xo-price__item--del,.xo-price__item--del *{color:{{ settings.compare_price_color | default: '#999999' }}!important;font-weight:{{ settings.compare_price_weight | default: '400' }}!important;font-size:{{ settings.compare_price_size | default: 16 }}px!important;font-family:{{ price_font }}!important;opacity:1!important}
      @media(max-width:768px){
        .xo-price__item--accent{font-size:{{ settings.sale_price_size_mobile | default: 20 }}px!important}
        .xo-price__item--del,.xo-price__item--del *{font-size:{{ settings.compare_price_size_mobile | default: 14 }}px!important}
      }
      /* Add to Cart button — override via CSS variables the theme reads */
      xo-cart-add{--color-light-button:{{ settings.atc_bg_color.red | default: 30 }},{{ settings.atc_bg_color.green | default: 176 }},{{ settings.atc_bg_color.blue | default: 20 }};--color-light-button-text:{{ settings.atc_text_color.red | default: 255 }},{{ settings.atc_text_color.green | default: 255 }},{{ settings.atc_text_color.blue | default: 255 }};--color-dark-button:{{ settings.atc_bg_hover_color.red | default: 23 }},{{ settings.atc_bg_hover_color.green | default: 144 }},{{ settings.atc_bg_hover_color.blue | default: 16 }};--color-dark-button-text:{{ settings.atc_text_color.red | default: 255 }},{{ settings.atc_text_color.green | default: 255 }},{{ settings.atc_text_color.blue | default: 255 }};--buttons-background-opacity:1}
      .xo-cart-add .xo-btn{font-size:{{ settings.atc_font_size | default: 16 }}px!important;font-weight:{{ settings.atc_font_weight | default: '600' }}!important;border-radius:{{ settings.atc_border_radius | default: 6 }}px!important;font-family:{{ btn_font }}!important}
      /* Product page — match container width to header */
      xo-product .xo-container--wide{max-width:var(--xo-container-width,1400px)!important;padding-left:var(--xo-container-gap,20px)!important;padding-right:var(--xo-container-gap,20px)!important}
      /* Buy Now button font (color/hover handled in buy-button.liquid) */
      .shopify-payment-button__button--unbranded{font-family:{{ btn_font }}!important}
      /* Sale badge (Save X%) — product cards + product page inline badge */
      .xo-badge-sale{background-color:{{ settings.sale_badge_bg | default: '#000000' }}!important;color:{{ settings.sale_badge_color | default: '#ffffff' }}!important}
      .badge{background-color:{{ settings.sale_badge_bg | default: '#000000' }}!important}
      .badge span{color:{{ settings.sale_badge_color | default: '#ffffff' }}!important}
      /* Size Guide — clean bordered link style */
      .addon-buttons__trigger{display:inline-flex!important;align-items:center!important;gap:0!important;background:transparent!important;border:1.5px solid #c8c8c8!important;border-radius:20px!important;color:#444!important;font-size:13px!important;font-weight:500!important;letter-spacing:0.3px!important;padding:6px 14px!important;cursor:pointer!important;text-decoration:none!important;box-shadow:none!important;transition:border-color 0.2s,color 0.2s!important;transform:none!important}
      .addon-buttons__trigger::before{content:'\2192\00a0';font-size:13px;color:inherit}
      .addon-buttons__trigger::after{content:'\00a0\2190';font-size:13px;color:inherit}
      .addon-buttons__trigger:hover{border-color:#1364b0!important;color:#1364b0!important;background:transparent!important;box-shadow:none!important;transform:none!important}
      .addon-buttons__trigger svg,.addon-buttons__trigger .icon{display:none!important}
      .addon-buttons__trigger span{color:inherit!important}
    </style>

    {% render 'google-fonts-link' %}

    {% if settings.font_body_selection == 'shopify_fonts' %}
      <link
        href='{{ settings.type_body_font | font_url | preload_tag: as: 'font' }}'
        type='font/woff2'
        crossorigin
      >
    {% endif %}

    {% if settings.font_heading_selection == 'shopify_fonts' %}
      <link
        href='{{ settings.type_header_font | font_url | preload_tag: as: 'font' }}'
        type='font/woff2'
        crossorigin
      >
    {% endif %}

    <script>
      document.documentElement.className = document.documentElement.className.replace('no-js', 'js');
      if (Shopify.designMode) {
        document.documentElement.classList.add('shopify-design-mode');
      }
    </script>

    <script src='{{ 'xo-webcomponents.min.js' | asset_url }}' defer></script>
    <script src='{{ 'main.min.js' | asset_url }}' defer></script>
  </head>

  <body class='gradient'>
    <div id='xo-root'>
      {% liquid
        assign button_text = 'accessibility.skip_to_text' | t
        render 'button', link: '#xo-main-content', class: 'xo-skip-to-content xo-visually-hidden', text: button_text
      %}

      {%- if template contains 'index' or template contains 'home' -%}
        {%- if settings.header_style == 'default' -%}
          {%- assign header = 'header-v1' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-2' -%}
        {%- if settings.header_style == 'default' -%}
          {%- assign header = 'header-v2' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-3' -%}
        {%- if settings.header_style == 'default' -%}
          {%- assign header = 'header-v3' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-4' -%}
        {%- if settings.header_style == 'default' -%}
          {%- assign header = 'header-v4' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-5' -%}
        {%- if settings.header_style == 'default' -%}
          {%- assign header = 'header-v5' %}
        {%- endif -%}
      {%- endif -%}

      {%- if settings.header_style != 'default' -%}
        {%- assign header = settings.header_style %}
      {%- endif -%}

      {% case header %}
        {% when 'header-v1' %}
          {% sections 'header-group' %}
        {% when 'header-v2' %}
          {% sections 'header2-group' %}
        {% when 'header-v3' %}
          {% sections 'header3-group' %}
        {% when 'header-v4' %}
          {% sections 'header4-group' %}
        {% when 'header-v5' %}
          {% sections 'header5-group' %}
        {%- else -%}
          {% sections 'header-group' %}
      {% endcase %}

      <main
        id='xo-main-content'
        class='content-for-layout focus-none'
        role='main'
        tabindex='-1'
      >
        {{ content_for_layout }}
      </main>

      {%- if template contains 'index' or template contains 'home' -%}
        {%- if settings.footer_style == 'default' -%}
          {%- assign footer = 'footer-v1' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-2' -%}
        {%- if settings.footer_style == 'default' -%}
          {%- assign footer = 'footer-v2' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-3' -%}
        {%- if settings.footer_style == 'default' -%}
          {%- assign footer = 'footer-v3' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-4' -%}
        {%- if settings.footer_style == 'default' -%}
          {%- assign footer = 'footer-v4' %}
        {%- endif -%}
      {%- endif -%}

      {%- if template contains 'home-5' -%}
        {%- if settings.footer_style == 'default' -%}
          {%- assign footer = 'footer-v5' %}
        {%- endif -%}
      {%- endif -%}

      {%- if settings.footer_style != 'default' -%}
        {%- assign footer = settings.footer_style %}
      {%- endif -%}

      {% case footer %}
        {% when 'footer-v1' %}
          {% sections 'footer-group' %}
        {% when 'footer-v2' %}
          {% sections 'footer2-group' %}
        {% when 'footer-v3' %}
          {% sections 'footer3-group' %}
        {% when 'footer-v4' %}
          {% sections 'footer4-group' %}
        {% when 'footer-v5' %}
          {% sections 'footer5-group' %}
        {%- else -%}
          {% sections 'footer-group' %}
      {% endcase %}

      {% sections 'overlay-group' %}
      {% sections 'popup-group' %}

      <ul hidden>
        <li id='a11y-refresh-page-message'>{{ 'accessibility.refresh_page' | t }}</li>
        <li id='a11y-new-window-message'>{{ 'accessibility.link_messages.new_window' | t }}</li>
      </ul>

      {% render 'scroll-top' %}
      {% render 'toolbar' %}
    </div>

    <script>
      window.shopUrl = '{{ request.origin }}';
      window.routes = {
        cart_add_url: '{{ routes.cart_add_url }}',
        cart_change_url: '{{ routes.cart_change_url }}',
        cart_update_url: '{{ routes.cart_update_url }}',
        cart_url: '{{ routes.cart_url }}',
        predictive_search_url: '{{ routes.predictive_search_url }}',
      };

      window.cartStrings = {
        error: `{{ 'sections.cart.cart_error' | t }}`,
        quantityError: `{{ 'sections.cart.cart_quantity_error_html' | t: quantity: '[quantity]' }}`,
      };

      window.variantStrings = {
        addToCart: `{{ 'products.product.add_to_cart' | t }}`,
        soldOut: `{{ 'products.product.sold_out' | t }}`,
        unavailable: `{{ 'products.product.unavailable' | t }}`,
      };

      window.accessibilityStrings = {
        imageAvailable: `{{ 'products.product.media.image_available' | t: index: '[index]' }}`,
        shareSuccess: `{{ 'general.share.success_message' | t }}`,
        pauseSlideshow: `{{ 'sections.slideshow.pause_slideshow' | t }}`,
        playSlideshow: `{{ 'sections.slideshow.play_slideshow' | t }}`,
      };
    </script>
  </body>
</html>
