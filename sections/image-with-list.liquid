<section class='img-list' id='img-list-{{ section.id }}' style='background-color: {{ section.settings.bg_color }};'>
  {% if section.settings.section_heading != blank or section.settings.subheading != blank %}
    <div class='img-list__header'>
      {% if section.settings.section_heading != blank %}
        <h2 class='img-list__heading' style='color: {{ section.settings.heading_color }}; font-weight: {{ section.settings.heading_font_weight }}; max-width: {{ section.settings.heading_max_width }}; text-align: {{ section.settings.heading_text_align }};'>
          {{ section.settings.section_heading }}
        </h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class='img-list__subheading' style='color: {{ section.settings.subheading_color }}; font-size: {{ section.settings.subheading_font_size }}px; text-align: {{ section.settings.subheading_text_align }}; max-width: {{ section.settings.subheading_max_width }};'>
          {{ section.settings.subheading }}
        </p>
      {% endif %}
    </div>
  {% endif %}

  <div class='img-list__body img-list__body--{{ section.settings.image_position }}'>
    <div class='img-list__image-col'>
      {% if section.settings.main_image != blank %}
        <img
          src='{{ section.settings.main_image | image_url: width: 1000 }}'
          alt='{{ section.settings.section_heading }}'
          class='img-list__img'
          style='border-radius: {{ section.settings.image_border_radius }}px;'
          loading='lazy'
        >
      {% endif %}
    </div>

    <div class='img-list__features-col'>
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class='img-list__feature-item' style='background: {{ section.settings.feature_items_bg }}; border-radius: {{ section.settings.feature_item_border_radius }}px; padding: {{ section.settings.feature_item_padding }}; margin-bottom: {{ section.settings.feature_item_margin_bottom }}px;' {{ block.shopify_attributes }}>
            <div class='img-list__feature-icon' style='width: {{ section.settings.feature_item_icon_size }}px; height: {{ section.settings.feature_item_icon_size }}px; flex-shrink: 0;'>
              {% if block.settings.icon_image != blank %}
                <img src='{{ block.settings.icon_image | image_url: width: 80 }}' alt='' width='{{ section.settings.feature_item_icon_size }}' height='{{ section.settings.feature_item_icon_size }}' loading='lazy'>
              {% else %}
                <div class='img-list__feature-icon-placeholder' style='background: #1364b0; border-radius: 50%; width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; color: #fff; font-weight: 700;'>✓</div>
              {% endif %}
            </div>
            <div class='img-list__feature-text'>
              {% if block.settings.heading != blank %}
                <h3 class='img-list__feature-heading' style='font-size: {{ block.settings.heading_font_size }}px; font-weight: {{ block.settings.heading_font_weight }}; color: {{ block.settings.heading_color }}; line-height: {{ block.settings.heading_line_height }}; margin: 0 0 4px;'>
                  {{ block.settings.heading }}
                </h3>
              {% endif %}
              {% if block.settings.description != blank %}
                <p class='img-list__feature-desc' style='font-size: {{ block.settings.description_font_size }}px; color: {{ block.settings.description_color }}; margin: 0; line-height: 1.55;'>
                  {{ block.settings.description }}
                </p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #img-list-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    box-sizing: border-box;
  }
  #img-list-{{ section.id }} .img-list__header {
    max-width: 1500px;
    margin: 0 auto 40px;
    padding: 0 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 14px;
  }
  #img-list-{{ section.id }} .img-list__heading {
    margin: 0;
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    line-height: {{ section.settings.heading_line_height_desktop }};
  }
  #img-list-{{ section.id }} .img-list__subheading { margin: 0; }

  #img-list-{{ section.id }} .img-list__body {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: flex-start;
    gap: 40px;
  }
  #img-list-{{ section.id }} .img-list__body--left  { flex-direction: row; }
  #img-list-{{ section.id }} .img-list__body--right { flex-direction: row-reverse; }

  #img-list-{{ section.id }} .img-list__image-col {
    flex: 0 0 {{ section.settings.image_width_desktop }};
    max-width: {{ section.settings.image_width_desktop }};
  }
  #img-list-{{ section.id }} .img-list__img { width: 100%; height: auto; display: block; }
  #img-list-{{ section.id }} .img-list__features-col { flex: 1; }
  #img-list-{{ section.id }} .img-list__feature-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    box-sizing: border-box;
  }
  #img-list-{{ section.id }} .img-list__feature-text { flex: 1; }

  @media (max-width: 768px) {
    #img-list-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    #img-list-{{ section.id }} .img-list__header { padding: 0 16px; margin-bottom: 24px; }
    #img-list-{{ section.id }} .img-list__body {
      flex-direction: column;
      padding: 0 16px;
      gap: 24px;
    }
    #img-list-{{ section.id }} .img-list__image-col { flex: none; max-width: 100%; width: 100%; }
    #img-list-{{ section.id }} .img-list__heading { font-size: {{ section.settings.heading_font_size_mobile }}px; line-height: {{ section.settings.heading_line_height_mobile }}; }
  }
</style>

