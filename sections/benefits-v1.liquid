{% capture breakpoints %}
  {
    1024: {
      perView: 3,
    },
    768: {
      perView: 2,
    },
    576: {
      perView: 1,
    },
  }
{% endcapture %}

<section {% render 'section-attr' %}>
  {% render 'section-bg-image' %}
  <xo-container {% render 'section-layout' %}>
    {% if section.settings.title %}
      <div class='benefits-v1__header'>
        {% if section.settings.subtitle %}
          <p class='benefits-v1__subtitle'>{{ section.settings.subtitle }}</p>
        {% endif %}
        <h2 class='benefits-v1__title'>{{ section.settings.title }}</h2>
      </div>
    {% endif %}

    <xo-carousel
      xo-per-view='3'
      xo-gap='{{ section.settings.gap }}'
      xo-breakpoints='{{ breakpoints }}'
      xo-adaptive-height='false'
    >
      <xo-carousel-inner>
        <xo-carousel-list role='list' aria-label='{{ 'general.slider.name' | t }}'>
          {%- for block in section.blocks -%}
            <xo-carousel-slide aria-roledescription='{{ 'sections.slideshow.slide' | t }}' aria-label='{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}'>
              <xo-animate xo-cascade class='benefits-v1__item'>
                <div class='benefits-v1__icon'>
                  {% if block.settings.svg != empty %}
                    {{ block.settings.svg }}
                  {% elsif block.settings.image_svg != empty %}
                    {% render 'image', image: block.settings.image_svg %}
                  {% endif %}
                </div>
                <div class='benefits-v1__content'>
                  <h3 class='benefits-v1__item-title'>
                    {{ block.settings.title }}
                  </h3>
                  <p class='benefits-v1__description'>
                    {{ block.settings.description }}
                  </p>
                </div>
              </xo-animate>
            </xo-carousel-slide>
          {%- endfor -%}
        </xo-carousel-list>
      </xo-carousel-inner>
    </xo-carousel>
  </xo-container>
</section>

<style>
  .benefits-v1__header {
    text-align: center;
    margin-bottom: {{ section.settings.header_margin }}px;
  }

  .benefits-v1__subtitle {
    font-size: {{ section.settings.subtitle_font_size }}rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary, #666);
    margin: 0 0 12px 0;
  }

  .benefits-v1__title {
    font-size: {{ section.settings.title_font_size }}rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text, #000);
    line-height: 1.2;
  }

  .benefits-v1__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ section.settings.item_gap }}px;
    padding: {{ section.settings.item_padding }}px;
  }

  .benefits-v1__icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .benefits-v1__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .benefits-v1__content {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .benefits-v1__item-title {
    font-size: {{ section.settings.item_title_font_size }}rem;
    font-weight: 600;
    margin: 0;
    color: var(--color-text, #000);
  }

  .benefits-v1__description {
    font-size: {{ section.settings.description_font_size }}rem;
    line-height: 1.7;
    margin: 0;
    color: var(--color-text-secondary, #666);
  }

  @media (max-width: 1024px) {
    .benefits-v1__title {
      font-size: calc({{ section.settings.title_font_size }}rem - 0.3rem);
    }

    .benefits-v1__icon {
      width: calc({{ section.settings.icon_size }}px * 0.9);
      height: calc({{ section.settings.icon_size }}px * 0.9);
    }
  }

  @media (max-width: 768px) {
    .benefits-v1__title {
      font-size: calc({{ section.settings.title_font_size }}rem - 0.75rem);
    }

    .benefits-v1__header {
      margin-bottom: calc({{ section.settings.header_margin }}px * 0.75);
    }

    .benefits-v1__icon {
      width: calc({{ section.settings.icon_size }}px * 0.75);
      height: calc({{ section.settings.icon_size }}px * 0.75);
    }

    .benefits-v1__item-title {
      font-size: calc({{ section.settings.item_title_font_size }}rem - 0.2rem);
    }

    .benefits-v1__description {
      font-size: calc({{ section.settings.description_font_size }}rem - 0.05rem);
    }
  }

  @media (max-width: 576px) {
    xo-carousel {
      display: block !important;
    }

    xo-carousel-inner,
    xo-carousel-list {
      display: contents;
    }

    xo-carousel-slide {
      display: block !important;
      width: 100% !important;
      margin: 0 !important;
    }

    .benefits-v1__item {
      gap: 12px;
      padding: 12px 10px;
      margin-bottom: 16px;
    }

    .benefits-v1__icon {
      width: {{ section.settings.mobile_icon_size }}px;
      height: {{ section.settings.mobile_icon_size }}px;
      margin-bottom: 8px;
    }

    .benefits-v1__item-title {
      font-size: {{ section.settings.mobile_item_title_font_size }}rem;
      font-weight: 600;
      margin-bottom: 6px;
    }

    .benefits-v1__title {
      font-size: 2.8rem;
      line-height: 1.22;
      margin-bottom: 12px;
    }

    .benefits-v1__description {
      font-size: {{ section.settings.mobile_description_font_size }}rem;
      line-height: {{ section.settings.mobile_description_line_height }};
      color: var(--color-text-secondary, #666);
    }

    .benefits-v1__content {
      gap: 8px;
      max-width: 332px;
      margin: 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.benefits_v1.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "t:sections.benefits_v1.settings.title.label",
      "default": "Shoes Proven To Increase Comfort & Foot Mobility"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:sections.benefits_v1.settings.subtitle.label"
    },
    {
      "type": "header",
      "content": "Typography & Font Sizes"
    },
    {
      "type": "range",
      "id": "title_font_size",
      "label": "Title Font Size (rem)",
      "min": 1.5,
      "max": 4,
      "step": 0.1,
      "default": 2.5
    },
    {
      "type": "range",
      "id": "subtitle_font_size",
      "label": "Subtitle Font Size (rem)",
      "min": 0.7,
      "max": 1.2,
      "step": 0.1,
      "default": 0.9
    },
    {
      "type": "range",
      "id": "item_title_font_size",
      "label": "Item Title Font Size (rem)",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.5
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description Font Size (rem)",
      "min": 0.8,
      "max": 1.5,
      "step": 0.1,
      "default": 1
    },
    {
      "type": "header",
      "content": "Spacing & Layout"
    },
    {
      "type": "range",
      "id": "header_margin",
      "label": "Header Bottom Margin (px)",
      "min": 20,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "range",
      "id": "gap",
      "min": 10,
      "max": 80,
      "step": 1,
      "unit": "px",
      "label": "Carousel Gap (px)",
      "default": 30
    },
    {
      "type": "range",
      "id": "item_gap",
      "label": "Item Internal Gap (px)",
      "min": 10,
      "max": 40,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "item_padding",
      "label": "Item Padding (px)",
      "min": 10,
      "max": 50,
      "step": 2,
      "default": 20
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon Size (px)",
      "min": 80,
      "max": 200,
      "step": 10,
      "default": 120
    },
    {
      "type": "header",
      "content": "Mobile Size Controls"
    },
    {
      "type": "range",
      "id": "mobile_icon_size",
      "label": "Mobile Icon Size (px)",
      "min": 60,
      "max": 180,
      "step": 2,
      "default": 116
    },
    {
      "type": "range",
      "id": "mobile_item_title_font_size",
      "label": "Mobile Item Title Font Size (rem)",
      "min": 0.8,
      "max": 2.2,
      "step": 0.1,
      "default": 1.4
    },
    {
      "type": "range",
      "id": "mobile_description_font_size",
      "label": "Mobile Description Font Size (rem)",
      "min": 0.7,
      "max": 1.8,
      "step": 0.1,
      "default": 1.2
    },
    {
      "type": "range",
      "id": "mobile_description_line_height",
      "label": "Mobile Description Line Height",
      "min": 1.1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "select",
      "id": "width",
      "label": "t:sections.all.width.label",
      "default": "box",
      "options": [
        {
          "value": "box",
          "label": "t:sections.all.width.options__1.label"
        },
        {
          "value": "wide",
          "label": "t:sections.all.width.options__2.label"
        },
        {
          "value": "fullwidth",
          "label": "t:sections.all.width.options__3.label"
        }
      ]
    },
    {
      "type": "number",
      "id": "fullwidth_margin",
      "label": "t:sections.all.fullwidth_margin.label",
      "default": 0,
      "visible_if": "{{ section.settings.width == 'fullwidth' }}"
    },
    {
      "type": "header",
      "content": "t:sections.all.heading.content"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.color_scheme.label"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "t:sections.all.background_type.label",
      "options": [
        {
          "value": "color",
          "label": "t:sections.all.background_type.option__1.label"
        },
        {
          "value": "gradient",
          "label": "t:sections.all.background_type.option__2.label"
        },
        {
          "value": "image",
          "label": "t:sections.all.background_type.option__3.label"
        },
        {
          "value": "video",
          "label": "t:sections.all.background_type.option__4.label"
        }
      ],
      "default": "color"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:sections.all.background_color.label",
      "alpha": true,
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "t:sections.all.background_gradient.label",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "t:sections.all.background_image_desktop.label",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_mobile",
      "label": "t:sections.all.background_image_mobile.label",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "checkbox",
      "id": "use_parallax",
      "label": "t:sections.all.use_parallax.label",
      "default": true,
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "select",
      "id": "background_image_animation",
      "label": "t:sections.all.animation.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.animation.option__0.label"
        },
        {
          "value": "fade",
          "label": "t:sections.all.animation.option__1.label"
        },
        {
          "value": "fade-up",
          "label": "t:sections.all.animation.option__2.label"
        },
        {
          "value": "fade-down",
          "label": "t:sections.all.animation.option__3.label"
        },
        {
          "value": "fade-left",
          "label": "t:sections.all.animation.option__4.label"
        },
        {
          "value": "fade-right",
          "label": "t:sections.all.animation.option__5.label"
        },
        {
          "value": "zoom-in",
          "label": "t:sections.all.animation.option__6.label"
        },
        {
          "value": "zoom-out",
          "label": "t:sections.all.animation.option__7.label"
        },
        {
          "value": "rotate-left-up",
          "label": "t:sections.all.animation.option__8.label"
        },
        {
          "value": "rotate-right-up",
          "label": "t:sections.all.animation.option__9.label"
        },
        {
          "value": "snake-up",
          "label": "t:sections.all.animation.option__10.label"
        },
        {
          "value": "snake-down",
          "label": "t:sections.all.animation.option__11.label"
        },
        {
          "value": "snake-left",
          "label": "t:sections.all.animation.option__12.label"
        },
        {
          "value": "snake-right",
          "label": "t:sections.all.animation.option__13.label"
        },
        {
          "value": "3d-up",
          "label": "t:sections.all.animation.option__14.label"
        }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "textarea",
      "id": "background_video_url",
      "label": "t:sections.all.background_video_url.label",
      "visible_if": "{{ section.settings.background_type == 'video' }}"
    },
    {
      "type": "select",
      "id": "background_video_animation",
      "label": "t:sections.all.animation.label",
      "options": [
        {
          "value": "none",
          "label": "t:sections.all.animation.option__0.label"
        },
        {
          "value": "fade",
          "label": "t:sections.all.animation.option__1.label"
        },
        {
          "value": "fade-up",
          "label": "t:sections.all.animation.option__2.label"
        },
        {
          "value": "fade-down",
          "label": "t:sections.all.animation.option__3.label"
        },
        {
          "value": "fade-left",
          "label": "t:sections.all.animation.option__4.label"
        },
        {
          "value": "fade-right",
          "label": "t:sections.all.animation.option__5.label"
        },
        {
          "value": "zoom-in",
          "label": "t:sections.all.animation.option__6.label"
        },
        {
          "value": "zoom-out",
          "label": "t:sections.all.animation.option__7.label"
        },
        {
          "value": "rotate-left-up",
          "label": "t:sections.all.animation.option__8.label"
        },
        {
          "value": "rotate-right-up",
          "label": "t:sections.all.animation.option__9.label"
        },
        {
          "value": "snake-up",
          "label": "t:sections.all.animation.option__10.label"
        },
        {
          "value": "snake-down",
          "label": "t:sections.all.animation.option__11.label"
        },
        {
          "value": "snake-left",
          "label": "t:sections.all.animation.option__12.label"
        },
        {
          "value": "snake-right",
          "label": "t:sections.all.animation.option__13.label"
        },
        {
          "value": "3d-up",
          "label": "t:sections.all.animation.option__14.label"
        }
      ],
      "default": "none",
      "visible_if": "{{ section.settings.background_type == 'video' }}"
    },
    {
      "type": "color",
      "id": "background_overlay",
      "label": "t:sections.all.background_overlay.label",
      "alpha": true,
      "visible_if": "{{ section.settings.background_type == 'image' or section.settings.background_type == 'video' }}"
    },
    {
      "type": "number",
      "id": "background_margin",
      "label": "t:sections.all.background_margin.label",
      "default": 0
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.all.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.all.padding_bottom.label",
      "default": 50
    }
  ],
  "blocks": [
    {
      "name": "t:sections.benefits_v1.blocks.name",
      "type": "benefit",
      "settings": [
        {
          "type": "html",
          "id": "svg",
          "label": "t:sections.benefits_v1.blocks.svg.label"
        },
        {
          "type": "image_picker",
          "id": "image_svg",
          "label": "t:sections.benefits_v1.blocks.image_svg.label"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.benefits_v1.blocks.title.label"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.benefits_v1.blocks.description.label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.benefits_v1.presets.name",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "title": "General Foot Relief",
            "description": "Sore feet or general pain in the feet cause discomfort and prevent you from carrying out your daily tasks. Would you like to feel young again? Then you need shoes that provide relief and make you feel like you're walking on clouds."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Plantar Fasciitis",
            "description": "Plantar fasciitis usually begins with a dull, intermittent pain in the heel and gradually increases to create persistent discomfort. You need shoes that support your feet and thus alleviate this discomfort."
          }
        },
        {
          "type": "benefit",
          "settings": {
            "title": "Bunions/Hallux Valgus",
            "description": "Pain caused by bunions is often due to ill-fitting shoes. You need shoes with a wide toe box that give your feet some room to breathe and alleviate the discomfort caused by bunions."
          }
        }
      ]
    }
  ]
}
{% endschema %}
