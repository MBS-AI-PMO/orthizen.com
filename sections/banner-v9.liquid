

<div class='banner-v161'>
  <div
    {% render 'section-attr' %}
  >
    {% render 'section-bg-image' %}
    <xo-container
      {% render 'section-layout' %}
    >
      <xo-animate xo-cascade>
        <xo-grid
          style='--xo-col-gap:{{ section.settings.gap }}px ;--xo-row-gap:{{ section.settings.gap }}px ;'
        >
          <div class='banner-v161__item banner-v161__item-content' style='--xs:12;--sm:12;--lg:5'>
            <div class='banner-v161__content'>
              <xo-animate xo-cascade>
                <h3 class='banner-v161__subtitle'>{{ section.settings.subtitle }}</h3>
              </xo-animate>
              <xo-animate xo-cascade>
                <h2 class='banner-v161__title'>{{ section.settings.title }}</h2>
              </xo-animate>
              <xo-animate xo-cascade>
                <div class='banner-v161__description'>{{ section.settings.description }}</div>
              </xo-animate>
              {% render 'button',
                text: section.settings.button_text,
                link: section.settings.link_banner,
                mode: section.settings.button_mode,
                style: section.settings.button_style,
                size: section.settings.button_size,
                radius: section.settings.button_radius,
                padding: section.settings.button_padding
              %}
            </div>
          </div>
          <div class='banner-v161__item' style='--xs:12;--sm:12;--md:6;--lg:4'>
            <div class='{%- render 'hover-style' -%}'>
              <a href='{{ section.settings.link_banner }}' class='banner-v161__img'>
                {%- render 'image', image: section.settings.image1 -%}
              </a>
            </div>
          </div>
          <div class='banner-v161__item banner-v161__item--pd55' style='--xs:12;--sm:12;--md:6;--lg:3'>
            <div class='{%- render 'hover-style' -%}'>
              <a href='{{ section.settings.link_banner }}' class='banner-v161__img'>
                {%- render 'image', image: section.settings.image2 -%}
              </a>
            </div>
          </div>
        </xo-grid>
      </xo-animate>
    </xo-container>
  </div>
</div>

