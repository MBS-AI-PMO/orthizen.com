<section class='foot-pain' id='foot-pain-{{ section.id }}' style='background-color: {{ section.settings.bg_color }};'>
  <div class='foot-pain__container'>

    <div class='foot-pain__content'>
      {% if section.settings.heading != blank %}
        <h2 class='foot-pain__heading' style='color: {{ section.settings.heading_color }}; font-weight: {{ section.settings.heading_font_weight }};'>
          {{ section.settings.heading }}
        </h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class='foot-pain__subheading' style='color: {{ section.settings.subheading_color }}; font-size: {{ section.settings.subheading_font_size }}px; font-weight: {{ section.settings.subheading_font_weight }};'>
          {{ section.settings.subheading }}
        </p>
      {% endif %}

      {% assign checklist_blocks = section.blocks | where: 'type', 'checklist_item' %}
      {% if checklist_blocks.size > 0 %}
        <div class='foot-pain__checklist' style='--check-cols: {{ section.settings.checklist_columns }};'>
          {% for block in checklist_blocks %}
            <div class='foot-pain__check-item' style='margin-bottom: {{ section.settings.checklist_item_margin_bottom }}px;' {{ block.shopify_attributes }}>
              <span class='foot-pain__check-icon' style='color: {{ section.settings.checklist_check_color }};'>✓</span>
              <span class='foot-pain__check-text' style='font-size: {{ section.settings.checklist_font_size }}px; font-weight: {{ section.settings.checklist_font_weight }}; color: {{ section.settings.checklist_color }};'>{{ block.settings.text }}</span>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class='foot-pain__images'>
      {% if section.settings.image_1 != blank %}
        <img
          src='{{ section.settings.image_1 | image_url: width: 700 }}'
          alt=''
          class='foot-pain__img'
          style='border-radius: {{ section.settings.image_1_border_radius }}px;'
          loading='lazy'
        >
      {% endif %}
      {% if section.settings.image_2 != blank %}
        <img
          src='{{ section.settings.image_2 | image_url: width: 700 }}'
          alt=''
          class='foot-pain__img'
          style='border-radius: {{ section.settings.image_2_border_radius }}px;'
          loading='lazy'
        >
      {% endif %}
    </div>

  </div>
</section>

<style>
  #foot-pain-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    box-sizing: border-box;
  }
  #foot-pain-{{ section.id }} .foot-pain__container {
    max-width: 1500px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    align-items: flex-start;
    gap: 48px;
  }
  #foot-pain-{{ section.id }} .foot-pain__content { flex: 1; display: flex; flex-direction: column; gap: 20px; }
  #foot-pain-{{ section.id }} .foot-pain__heading {
    margin: 0;
    font-size: {{ section.settings.heading_font_size_desktop }}px;
    line-height: {{ section.settings.heading_line_height_desktop }};
  }
  #foot-pain-{{ section.id }} .foot-pain__subheading { margin: 0; line-height: 1.6; }
  #foot-pain-{{ section.id }} .foot-pain__checklist {
    display: grid;
    grid-template-columns: repeat(var(--check-cols, 2), 1fr);
    gap: 4px 16px;
  }
  #foot-pain-{{ section.id }} .foot-pain__check-item {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #foot-pain-{{ section.id }} .foot-pain__check-icon { font-size: 16px; flex-shrink: 0; font-weight: 700; }
  #foot-pain-{{ section.id }} .foot-pain__check-text { line-height: 1.4; }

  #foot-pain-{{ section.id }} .foot-pain__images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ section.settings.images_gap }}px;
    flex: 0 0 45%;
    max-width: 45%;
  }
  #foot-pain-{{ section.id }} .foot-pain__img { width: 100%; height: auto; display: block; object-fit: cover; }

  @media (max-width: 768px) {
    #foot-pain-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
    #foot-pain-{{ section.id }} .foot-pain__container {
      flex-direction: column;
      padding: 0 16px;
      gap: 28px;
    }
    #foot-pain-{{ section.id }} .foot-pain__heading { font-size: {{ section.settings.heading_font_size_mobile }}px; line-height: {{ section.settings.heading_line_height_mobile }}; }
    #foot-pain-{{ section.id }} .foot-pain__images { flex: none; max-width: 100%; width: 100%; }
    #foot-pain-{{ section.id }} .foot-pain__checklist { grid-template-columns: 1fr 1fr; }
  }
</style>

