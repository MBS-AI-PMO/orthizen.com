{% liquid
  assign layout = section.settings.layout
  assign usp_blocks = section.blocks | where: 'type', 'usp_item'
%}

<section class='hero-banner' id='hero-{{ section.id }}' style='background-color: {{ section.settings.bg_color }};'>
  <div class='hero-banner__container hero-banner__container--{{ layout }}'>

    <div class='hero-banner__content'>
      {% if section.settings.show_expert_badge and section.settings.expert_badge_text != blank %}
        <div class='hero-banner__expert-badge' style='background: {{ section.settings.expert_badge_bg }}; color: {{ section.settings.expert_badge_color }}; border-radius: {{ section.settings.expert_badge_border_radius }}px; font-weight: {{ section.settings.expert_badge_font_weight }};'>
          {{ section.settings.expert_badge_text }}
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class='hero-banner__heading' style='color: {{ section.settings.heading_color }}; font-weight: {{ section.settings.heading_font_weight }};'>
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.subtext != blank %}
        <p class='hero-banner__subtext' style='color: {{ section.settings.subtext_color }}; font-weight: {{ section.settings.subtext_font_weight }};'>
          {{ section.settings.subtext }}
        </p>
      {% endif %}

      {% if section.settings.cta_text != blank %}
        <a href='{{ section.settings.cta_url }}' class='hero-banner__cta' style='background-color: {{ section.settings.cta_bg_color }}; color: {{ section.settings.cta_text_color }}; font-weight: {{ section.settings.cta_font_weight }}; border-radius: {{ section.settings.cta_border_radius }}px;'>
          {{ section.settings.cta_text }}
        </a>
      {% endif %}

      {% if section.settings.show_guarantee_badge and section.settings.guarantee_text != blank %}
        <p class='hero-banner__guarantee' style='color: {{ section.settings.guarantee_color }}; font-size: {{ section.settings.guarantee_font_size }}px;'>
          ✓ {{ section.settings.guarantee_text }}
        </p>
      {% endif %}

      {% if usp_blocks.size > 0 %}
        <div class='hero-banner__usp-grid'>
          {% for block in usp_blocks %}
            <div class='hero-banner__usp-item' {{ block.shopify_attributes }}>
              <div class='hero-banner__usp-icon' style='background-color: {{ block.settings.icon_bg_color }};'>
                {% if block.settings.icon_image != blank %}
                  <img src='{{ block.settings.icon_image | image_url: width: 60 }}' alt='{{ block.settings.text }}' width='24' height='24' loading='lazy'>
                {% else %}
                  <span>✓</span>
                {% endif %}
              </div>
              <span class='hero-banner__usp-text' style='font-size: {{ block.settings.text_font_size }}px; font-weight: {{ block.settings.text_font_weight }}; color: {{ block.settings.text_color }};'>{{ block.settings.text }}</span>
            </div>
            {% unless forloop.last %}<div class='hero-banner__usp-divider'></div>{% endunless %}
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class='hero-banner__media'>
      {% if section.settings.desktop_image != blank %}
        <img
          src='{{ section.settings.desktop_image | image_url: width: 1400 }}'
          alt='{{ section.settings.heading }}'
          class='hero-banner__img hero-banner__img--desktop'
          loading='eager'
          fetchpriority='high'
        >
      {% endif %}
      {% if section.settings.mobile_image != blank %}
        <img
          src='{{ section.settings.mobile_image | image_url: width: 800 }}'
          alt='{{ section.settings.heading }}'
          class='hero-banner__img hero-banner__img--mobile'
          loading='eager'
        >
      {% elsif section.settings.desktop_image != blank %}
        <img
          src='{{ section.settings.desktop_image | image_url: width: 800 }}'
          alt='{{ section.settings.heading }}'
          class='hero-banner__img hero-banner__img--mobile'
          loading='eager'
        >
      {% endif %}
    </div>

  </div>
</section>

<style>
  #hero-{{ section.id }} {
    width: 100%;
    box-sizing: border-box;
    overflow: hidden;
  }
  #hero-{{ section.id }} .hero-banner__container {
    max-width: 1500px;
    margin: 0 auto;
    display: flex;
    align-items: stretch;
    min-height: {{ section.settings.desktop_min_height }}px;
  }
  #hero-{{ section.id }} .hero-banner__container--image_right { flex-direction: row; }
  #hero-{{ section.id }} .hero-banner__container--image_left  { flex-direction: row-reverse; }

  #hero-{{ section.id }} .hero-banner__content {
    flex: 0 0 {{ section.settings.desktop_content_max_width }};
    max-width: {{ section.settings.desktop_content_max_width }};
    padding: {{ section.settings.padding_top_desktop }}px 40px {{ section.settings.padding_bottom_desktop }}px 40px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-start;
    justify-content: center;
    text-align: {{ section.settings.desktop_text_align }};
    box-sizing: border-box;
  }
  #hero-{{ section.id }} .hero-banner__expert-badge {
    display: inline-block;
    font-size: {{ section.settings.expert_badge_font_size_desktop }}px;
    padding: {{ section.settings.expert_badge_padding }};
  }
  #hero-{{ section.id }} .hero-banner__heading {
    margin: 0;
    font-size: {{ section.settings.heading_size_desktop }}px;
    line-height: {{ section.settings.heading_line_height_desktop }};
  }
  #hero-{{ section.id }} .hero-banner__subtext {
    margin: 0;
    font-size: {{ section.settings.subtext_font_size_desktop }}px;
    line-height: {{ section.settings.subtext_line_height }};
  }
  #hero-{{ section.id }} .hero-banner__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: {{ section.settings.cta_font_size }}px;
    letter-spacing: {{ section.settings.cta_letter_spacing }};
    padding: {{ section.settings.cta_padding }};
    height: {{ section.settings.cta_height }}px;
    width: {{ section.settings.cta_width_desktop }};
    box-sizing: border-box;
    transition: opacity 0.2s;
  }
  #hero-{{ section.id }} .hero-banner__cta:hover { opacity: 0.88; }
  #hero-{{ section.id }} .hero-banner__guarantee {
    margin: 0;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  #hero-{{ section.id }} .hero-banner__usp-grid {
    display: flex;
    align-items: center;
    background: #f0f0f0;
    border-radius: 8px;
    padding: 10px 14px;
    width: 100%;
    box-sizing: border-box;
    gap: 0;
  }
  #hero-{{ section.id }} .hero-banner__usp-item {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    justify-content: center;
  }
  #hero-{{ section.id }} .hero-banner__usp-icon {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #fff;
    font-size: 14px;
    font-weight: 700;
  }
  #hero-{{ section.id }} .hero-banner__usp-icon img {
    width: 22px;
    height: 22px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  #hero-{{ section.id }} .hero-banner__usp-text { line-height: 1.3; max-width: 85px; }
  #hero-{{ section.id }} .hero-banner__usp-divider {
    width: 1px;
    height: 36px;
    background: #d0d0d0;
    flex-shrink: 0;
    margin: 0 4px;
  }
  #hero-{{ section.id }} .hero-banner__media {
    flex: 1;
    position: relative;
    overflow: hidden;
    min-height: {{ section.settings.desktop_min_height }}px;
  }
  #hero-{{ section.id }} .hero-banner__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: {{ section.settings.image_position_x }} {{ section.settings.image_position_y }};
    display: block;
  }
  #hero-{{ section.id }} .hero-banner__img--mobile { display: none; }

  @media (max-width: 768px) {
    #hero-{{ section.id }} .hero-banner__container {
      flex-direction: column;
      min-height: unset;
    }
    #hero-{{ section.id }} .hero-banner__content {
      flex: none;
      max-width: 100%;
      width: 100%;
      padding: {{ section.settings.padding_top_mobile }}px 16px {{ section.settings.padding_bottom_mobile }}px 16px;
      text-align: {{ section.settings.mobile_text_align }};
      align-items: {% if section.settings.mobile_text_align == 'center' %}center{% else %}flex-start{% endif %};
      order: 1;
    }
    #hero-{{ section.id }} .hero-banner__expert-badge { font-size: {{ section.settings.expert_badge_font_size_mobile }}px; }
    #hero-{{ section.id }} .hero-banner__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      line-height: {{ section.settings.heading_line_height_mobile }};
    }
    #hero-{{ section.id }} .hero-banner__subtext {
      font-size: {{ section.settings.subtext_font_size_mobile }}px;
      margin: {{ section.settings.subtext_margin_mobile }};
    }
    #hero-{{ section.id }} .hero-banner__cta { width: {{ section.settings.cta_width_mobile }}; }
    #hero-{{ section.id }} .hero-banner__media {
      width: 100%;
      order: 0;
      min-height: {{ section.settings.mobile_image_height }}px;
    }
    #hero-{{ section.id }} .hero-banner__img--desktop { display: none; }
    #hero-{{ section.id }} .hero-banner__img--mobile { display: block; }
  }
</style>

{% schema %}
{
