

{% liquid
  if section.settings.padding_top != null
    assign padding_top = '--pt: ' | append: section.settings.padding_top | append: ';'
  endif
  if section.settings.padding_bottom != null
    assign padding_bottom = '--pb: ' | append: section.settings.padding_bottom | append: ';'
  endif
%}

<section style='{{- padding_top -}} {{- padding_bottom }}' class='slideshow-v40'>
  <xo-animate xo-cascade>
    <xo-carousel
      xo-render-bullet='<span class="slideshow-v40__bullet"></span>'
      xo-type='none'
      {% if section.settings.autoplay %}
        xo-autoplay='{{ section.settings.speed | times: 1000 }}'
      {% endif %}
      xo-speed='400'
      xo-loop
      xo-hover-pause
    >
      <xo-carousel-inner>
        <xo-carousel-list role='list' aria-label='{{ 'general.slider.name' | t }}'>
          {% for block in section.blocks %}
            <xo-carousel-slide aria-roledescription='{{ 'sections.slideshow.slide' | t }}' aria-label='{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}'>
              <div class='slideshow-v40__slide {%- if block.settings.color_scheme %} color-{{ block.settings.color_scheme }}{% endif %}'>
                {% if block.settings.video != blank %}
                  <xo-video-cover
                    xo-src='{{ block.settings.video }}'
                    class='slideshow-v40__video'
                  ></xo-video-cover>
                {% elsif block.settings.background_image_desktop != blank or block.settings.background_image_mobile != blank %}
                  <xo-animate
                    xo-type='zoom-out'
                    xo-order='1'
                    xo-duration='1000'
                    class='slideshow-v40__bg-container'
                  >
                    {% if block.settings.background_image_desktop != blank %}
                      <div
                        class='xo-background-lazyload slideshow-v40__bg slideshow-v40__bg--desktop'
                        style='background-image: url("{{ block.settings.background_image_desktop | image_url: width: 100 }}")'
                      ></div>
                    {% endif %}
                    {% if block.settings.background_image_mobile != blank %}
                      <div
                        class='xo-background-lazyload slideshow-v40__bg slideshow-v40__bg--mobile'
                        style='background-image: url("{{ block.settings.background_image_mobile | image_url: width: 100 }}")'
                      ></div>
                    {% endif %}
                  </xo-animate>
                {% endif %}
                <div class='slideshow-v40__bg-color' style='background-color:{{block.settings.background_color}};background-image:{{block.settings.background_gradient}}'></div>
                <xo-container {% render 'section-layout' %}>
                  <xo-grid style='position: relative'>
                    {% if block.settings.reverse_layout == false %}
                      {% assign start_column = 2 %}
                      {% assign start_column_xxl = 1 %}
                    {% else %}
                      {% assign start_column = 8 %}
                      {% assign start_column_xxl = 9 %}
                    {% endif %}
                    <div
                      style='--xs: 12;--md: 5; --start-md:{{ start_column }};--xxl: 6; --start-xxl:{{ start_column_xxl }}'
                      class='slideshow-v40__text'
                    >
                      <xo-animate xo-type='{{block.settings.subtitle_animation}}' xo-order='1' xo-duration='700' xo-strength='5'>
                        <h3
                          class='slideshow-v40__subtitle'
                          style='--fontsize:{{block.settings.subtitle_font_size | remove: "rem" }}; --fontweight:{{block.settings.subtitle_font_weight}}'
                        >
                          {{ block.settings.subtitle }}
                        </h3>
                      </xo-animate>
                      <xo-animate xo-type='{{block.settings.title_animation}}' xo-order='3' xo-duration='700'>
                        <h2 class='slideshow-v40__title' style='--fontsize:{{block.settings.title_font_size | remove: "rem" }}; --fontweight:{{block.settings.title_font_weight}}'>
                          {{ block.settings.title }}
                        </h2>
                      </xo-animate>
                      <xo-animate xo-type='{{block.settings.description_animation}}' xo-order='6' xo-duration='700' xo-strength='3'>
                        <h3
                          class='slideshow-v40__description'
                          style='--fontsize:{{block.settings.description_font_size | remove: "rem" }}; --fontweight:{{block.settings.description_font_weight}}'
                        >
                          {{ block.settings.description }}
                        </h3>
                      </xo-animate>
                      <xo-animate xo-type='{{block.settings.button_animation}}' xo-order='9' xo-duration='700' xo-strength='3'>
                        <div class='slideshow-v40__button' {% if block.settings.button_color %}style='--button-color: {{ block.settings.button_color }}'{% endif %}>
                          {% render 'button',
                            text: block.settings.button_text,
                            link: block.settings.button_link,
                            mode: block.settings.button_mode,
                            style: block.settings.button_style,
                            size: block.settings.button_size,
                            radius: block.settings.button_radius,
                            padding: block.settings.button_padding
                          %}
                        </div>
                      </xo-animate>
                    </div>
                    <xo-carousel-pagination class='slideshow-v40__pagination'></xo-carousel-pagination>
                    <div class='slideshow-v40__arrows'>
                      <xo-carousel-prev class='slideshow-v40__arrow-btn'
                        ><button>{% render 'icon', name: 'arrow-left2', icon_size: '15' %}</button></xo-carousel-prev
                      >
                      <xo-carousel-next class='slideshow-v40__arrow-btn'
                        ><button>{% render 'icon', name: 'arrow-right2', icon_size: '15' %}</button></xo-carousel-next
                      >
                    </div>
                  </xo-grid>
                </xo-container>
                {% if section.settings.show_features_bar %}
                  <div class='slideshow-v40__features-bar' style='background-color: {{ section.settings.features_bar_bg }}'>
                    <xo-container>
                      <div class='slideshow-v40__features-grid'>
                        {% for i in (1..3) %}
                          {% assign icon_key = 'feature_' | append: i | append: '_icon' %}
                          {% assign title_key = 'feature_' | append: i | append: '_title' %}
                          {% assign feat_icon = section.settings[icon_key] %}
                          {% assign feat_title = section.settings[title_key] %}
                          {% if feat_title != blank %}
                            <div class='slideshow-v40__feature-item'>
                              <div class='slideshow-v40__feature-icon' style='background-color: {{ section.settings.features_icon_bg }}'>
                                {% if feat_icon != blank %}
                                  <img
                                    src='{{ feat_icon | image_url: width: 60 }}'
                                    alt='{{ feat_title }}'
                                    width='28'
                                    height='28'
                                    loading='lazy'
                                  >
                                {% endif %}
                              </div>
                              <span class='slideshow-v40__feature-text'>{{ feat_title }}</span>
                            </div>
                            {% unless forloop.last %}<div class='slideshow-v40__feature-divider'></div>{% endunless %}
                          {% endif %}
                        {% endfor %}
                      </div>
                    </xo-container>
                  </div>
                {% endif %}
              </div>
            </xo-carousel-slide>
          {% endfor %}
        </xo-carousel-list>
      </xo-carousel-inner>
    </xo-carousel>
  </xo-animate>
</section>

<style>
  .slideshow-v40 {
    --mobile-subtitle-size: {{ section.settings.mobile_subtitle_font_size }}rem;
    --mobile-title-size: {{ section.settings.mobile_title_font_size }}rem;
    --mobile-description-size: {{ section.settings.mobile_description_font_size }}rem;
  }

  /* Button color styling */
  .slideshow-v40__button .xo-btn {
    background-color: var(--button-color, transparent) !important;
    border: none !important;
  }

  .slideshow-v40__button .xo-btn:hover {
    background-color: var(--button-color, transparent) !important;
    opacity: 0.85;
    border: none !important;
  }

  /* Mobile: Stack image on top, text below */
  @media (max-width: 768px) {
    .slideshow-v40__slide {
      position: relative !important;
      display: block !important;
    }

    .slideshow-v40__bg-container,
    .slideshow-v40__video {
      position: relative !important;
      display: block !important;
      width: 100% !important;
      height: 300px !important;
      order: -1;
    }

    .slideshow-v40__slide xo-container {
      position: relative !important;
      z-index: 1;
    }

    .slideshow-v40__slide xo-grid {
      position: relative !important;
      display: block !important;
    }

    .slideshow-v40__text {
      --xs: 12 !important;
      --md: 12 !important;
      --start-md: 1 !important;
      position: relative !important;
      width: 100% !important;
      padding: 30px 20px !important;
      background: white;
      text-align: center;
    }

    .slideshow-v40__subtitle {
      font-size: var(--mobile-subtitle-size, 0.9rem) !important;
      text-align: center !important;
    }

    .slideshow-v40__title {
      font-size: var(--mobile-title-size, 1.8rem) !important;
      text-align: center !important;
    }

    .slideshow-v40__description {
      font-size: var(--mobile-description-size, 1rem) !important;
      text-align: center !important;
    }

    .slideshow-v40__pagination,
    .slideshow-v40__arrows {
      display: none !important;
    }
  }

  @media (max-width: 576px) {
    .slideshow-v40__bg-container,
    .slideshow-v40__video {
      height: 250px !important;
    }

    .slideshow-v40__text {
      padding: 20px 15px !important;
    }
  }

  /* Features bar */
  .slideshow-v40__features-bar {
    padding: 16px 0;
  }
  .slideshow-v40__features-grid {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .slideshow-v40__feature-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px 40px;
    flex: 1;
    justify-content: center;
  }
  .slideshow-v40__feature-divider {
    width: 1px;
    height: 40px;
    background-color: #cecece;
    flex-shrink: 0;
  }
  .slideshow-v40__feature-icon {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .slideshow-v40__feature-icon img {
    width: 26px;
    height: 26px;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  .slideshow-v40__feature-text {
    font-size: 13px;
    font-weight: 600;
    color: #1a1a1a;
    max-width: 90px;
    line-height: 1.3;
  }
  @media (max-width: 768px) {
    .slideshow-v40__feature-item {
      padding: 6px 16px;
      gap: 8px;
    }
    .slideshow-v40__feature-icon {
      width: 38px;
      height: 38px;
    }
    .slideshow-v40__feature-icon img {
      width: 20px;
      height: 20px;
    }
    .slideshow-v40__feature-text {
      font-size: 11px;
      max-width: 70px;
    }
    .slideshow-v40__feature-divider {
      height: 32px;
    }
  }
  @media (max-width: 480px) {
    .slideshow-v40__feature-item {
      padding: 4px 10px;
      gap: 7px;
    }
    .slideshow-v40__feature-icon {
      width: 32px;
      height: 32px;
    }
    .slideshow-v40__feature-icon img {
      width: 17px;
      height: 17px;
    }
    .slideshow-v40__feature-text {
      font-size: 10px;
      max-width: 60px;
    }
    .slideshow-v40__feature-divider {
      height: 28px;
    }
  }
</style>

{% schema %}
{
  "name": "t:sections.slideshow_v2.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "width",
      "label": "t:sections.all.width.label",
      "default": "box",
      "options": [
        {
          "value": "box",
          "label": "t:sections.all.width.options__1.label"
        },
        {
          "value": "wide",
          "label": "t:sections.all.width.options__2.label"
        },
        {
          "value": "fullwidth",
          "label": "t:sections.all.width.options__3.label"
        }
      ]
    },
    {
      "type": "number",
      "id": "fullwidth_margin",
      "label": "t:sections.all.fullwidth_margin.label",
      "default": 0,
      "visible_if": "{{ section.settings.width == 'fullwidth' }}"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "t:sections.slideshow_v2.settings.autoplay.label",
      "default": false
    },
    {
      "type": "range",
      "id": "speed",
      "min": 5,
      "max": 20,
      "step": 5,
      "label": "t:sections.slideshow_v2.settings.speed.label",
      "default": 5
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "t:sections.slideshow_v2.settings.padding_top.label",
      "default": 50
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "t:sections.slideshow_v2.settings.padding_bottom.label",
      "default": 50
    },
    {
      "type": "header",
      "content": "Mobile Font Sizes"
    },
    {
      "type": "range",
      "id": "mobile_subtitle_font_size",
      "min": 0.8,
      "max": 2,
      "step": 0.1,
      "unit": "rem",
      "label": "Mobile subtitle/badge font size",
      "default": 0.9
    },
    {
      "type": "range",
      "id": "mobile_title_font_size",
      "min": 1.2,
      "max": 3,
      "step": 0.1,
      "unit": "rem",
      "label": "Mobile title font size",
      "default": 1.8
    },
    {
      "type": "range",
      "id": "mobile_description_font_size",
      "min": 0.8,
      "max": 1.5,
      "step": 0.1,
      "unit": "rem",
      "label": "Mobile description font size",
      "default": 1
    },
    {
      "type": "header",
      "content": "Features Bar"
    },
    {
      "type": "checkbox",
      "id": "show_features_bar",
      "label": "Show features bar",
      "default": true
    },
    {
      "type": "color",
      "id": "features_bar_bg",
      "label": "Features bar background",
      "default": "#f0f0f0"
    },
    {
      "type": "color",
      "id": "features_icon_bg",
      "label": "Icon circle background",
      "default": "#1952a8"
    },
    {
      "type": "text",
      "id": "feature_1_title",
      "label": "Feature 1 title",
      "default": "12 Hours Of Comfort"
    },
    {
      "type": "image_picker",
      "id": "feature_1_icon",
      "label": "Feature 1 icon"
    },
    {
      "type": "text",
      "id": "feature_2_title",
      "label": "Feature 2 title",
      "default": "Arch Support"
    },
    {
      "type": "image_picker",
      "id": "feature_2_icon",
      "label": "Feature 2 icon"
    },
    {
      "type": "text",
      "id": "feature_3_title",
      "label": "Feature 3 title",
      "default": "Wide Toe Fit"
    },
    {
      "type": "image_picker",
      "id": "feature_3_icon",
      "label": "Feature 3 icon"
    }
  ],
  "blocks": [
    {
      "type": "slideshow",
      "name": "t:sections.slideshow_v2.settings.blocks.name",
      "settings": [
        {
          "type": "checkbox",
          "id": "reverse_layout",
          "label": "t:sections.slideshow_v2.settings.blocks.reverse_layout.label",
          "default": false
        },
        {
          "type": "header",
          "content": "t:sections.slideshow_v2.settings.blocks.subtitle_heading.content"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "t:sections.slideshow_v2.settings.blocks.subtitle.label",
          "default": "SECTION SUBTITLE"
        },
        {
          "type": "range",
          "id": "subtitle_font_size",
          "min": 1,
          "max": 3,
          "step": 0.1,
          "unit": "rem",
          "label": "t:sections.slideshow_v2.settings.blocks.subtitle_font_size.label",
          "default": 2
        },
        {
          "type": "range",
          "id": "subtitle_font_weight",
          "min": 300,
          "max": 700,
          "step": 100,
          "label": "t:sections.slideshow_v2.settings.blocks.subtitle_font_weight.label",
          "default": 600
        },
        {
          "type": "select",
          "id": "subtitle_animation",
          "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.label",
          "options": [
            {
              "value": "fade",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_1.label"
            },
            {
              "value": "fade-up",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_2.label"
            },
            {
              "value": "fade-down",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_3.label"
            },
            {
              "value": "fade-left",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_4.label"
            },
            {
              "value": "fade-right",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_5.label"
            },
            {
              "value": "zoom-in",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_6.label"
            },
            {
              "value": "zoom-out",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_7.label"
            },
            {
              "value": "rotate-left-up",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_8.label"
            },
            {
              "value": "rotate-right-up",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_9.label"
            },
            {
              "value": "snake-up",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_10.label"
            },
            {
              "value": "snake-down",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_11.label"
            },
            {
              "value": "snake-left",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_12.label"
            },
            {
              "value": "snake-right",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_13.label"
            },
            {
              "value": "3d-up",
              "label": "t:sections.slideshow_v2.settings.blocks.subtitle_animation.option_14.label"
            }
          ],
          "default": "fade-up"
        },
        {
          "type": "header",
          "content": "t:sections.slideshow_v2.settings.blocks.title_heading.content"
        },
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.slideshow_v2.settings.blocks.title.label",
          "default": "SECTION TITLE",
          "info": "t:sections.slideshow_v2.settings.blocks.title.content"
        },
        {
          "type": "range",
          "id": "title_font_size",
          "min": 5,
          "max": 10,
          "step": 0.1,
          "unit": "rem",
          "label": "t:sections.slideshow_v2.settings.blocks.title_font_size.label",
          "default": 6.4
        },
        {
