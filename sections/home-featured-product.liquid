{%- liquid
  assign fp        = section.settings.featured_product
  assign has_fp    = false
  if fp != blank
    assign has_fp  = true
  endif
-%}

<div {% render 'section-attr' %}>
  {% render 'section-bg-image' %}
  <xo-container {% render 'section-layout' %}>

    {%- comment -%} ── optional heading ── {%- endcomment -%}
    {%- if section.settings.subtitle != blank or section.settings.title != blank -%}
      <xo-animate xo-cascade class='hfp__heading'>
        {%- if section.settings.subtitle != blank -%}
          <p class='hfp__subtitle'>{{ section.settings.subtitle }}</p>
        {%- endif -%}
        {%- if section.settings.title != blank -%}
          <h2 class='hfp__title'>{{ section.settings.title }}</h2>
        {%- endif -%}
      </xo-animate>
    {%- endif -%}

    {%- if has_fp -%}
      {%- comment -%} ── product container – JS injects content here ── {%- endcomment -%}
      <div class='hfp__wrap'
           id='hfp-{{ section.id }}'
           data-product-url='{{ shop.url }}/products/{{ fp.handle }}'>

        {%- comment -%} shimmer skeleton shown until content loads {%- endcomment -%}
        <div class='hfp__skeleton' id='hfp-sk-{{ section.id }}' aria-hidden='true'>
          <div class='hfp__skeleton-image'></div>
          <div class='hfp__skeleton-body'>
            <div class='hfp__sk-line' style='width:72%;height:2.8rem'></div>
            <div class='hfp__sk-line' style='width:38%;height:2rem;margin-top:1.2rem'></div>
            <div class='hfp__sk-line' style='width:100%;height:1.1rem;margin-top:2rem'></div>
            <div class='hfp__sk-line' style='width:100%;height:1.1rem;margin-top:.6rem'></div>
            <div class='hfp__sk-line' style='width:55%;height:1.1rem;margin-top:.6rem'></div>
            <div class='hfp__sk-line' style='width:100%;height:5.2rem;margin-top:2.5rem'></div>
            <div class='hfp__sk-line' style='width:100%;height:5.2rem;margin-top:1rem'></div>
          </div>
        </div>

      </div>

      {%- if section.settings.show_view_btn -%}
        <div class='hfp__footer'>
          <a href='{{ fp.url }}' class='hfp__view-btn'>
            {{ section.settings.view_btn_text | default: 'View Full Product Page' }}
            <span class='hfp__view-btn-arrow' aria-hidden='true'>→</span>
          </a>
        </div>
      {%- endif -%}

    {%- else -%}
      {%- if request.design_mode -%}
        <div class='hfp__placeholder'>
          <svg viewBox='0 0 24 24' width='40' height='40' fill='none' stroke='currentColor' stroke-width='1.5' aria-hidden='true'>
            <rect x='3' y='3' width='18' height='18' rx='2'/><path d='M3 9h18M9 21V9'/>
          </svg>
          <p>Select a product in the theme editor to preview it here.</p>
        </div>
      {%- endif -%}
    {%- endif -%}

  </xo-container>
</div>

{%- if has_fp -%}
<script>
(function () {
  'use strict';
  var wrap     = document.getElementById('hfp-{{ section.id }}');
  var skeleton = document.getElementById('hfp-sk-{{ section.id }}');
  if (!wrap) return;

  var url = wrap.dataset.productUrl + '?section_id=quick-view-content';

  fetch(url)
    .then(function (r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.text();
    })
    .then(function (html) {
      /* remove shimmer */
      if (skeleton) skeleton.remove();

      /* parse & inject the fetched section HTML */
      var tmp = document.createElement('div');
      tmp.innerHTML = html;
      var injected = tmp.firstElementChild || tmp;
      wrap.appendChild(injected);

      /* re-initialise variant handler if the theme exposes it */
      if (typeof window.ProductInformationVariantHandler === 'function') {
        try {
          new window.ProductInformationVariantHandler(
            '#hfp-{{ section.id }} xo-product[xo-product-information]'
          ).init();
        } catch (_) {}
      }
    })
    .catch(function () {
      if (skeleton) {
        skeleton.innerHTML =
          '<p style="text-align:center;padding:3rem 1rem;opacity:.6">Could not load product preview.</p>';
      }
    });
})();
</script>
{%- endif -%}

<style>
/* ── layout wrapper ── */
.hfp__heading      { text-align: center; margin-bottom: 3.5rem; }
.hfp__subtitle     { font-size: 1.1rem; text-transform: uppercase; letter-spacing: .1em; opacity: .6; margin: 0 0 .6rem; }
.hfp__title        { font-size: 2.4rem; font-weight: 700; margin: 0; }

/* ── injected quickview content inherits its own styles; */
/*    we only ensure the container has a min-height during load ── */
.hfp__wrap         { position: relative; min-height: 42rem; }

/* ── shimmer skeleton ── */
@keyframes hfp-shimmer {
  0%   { background-position:  200% 0; }
  100% { background-position: -200% 0; }
}
.hfp__skeleton {
  display: grid;
  grid-template-columns: 55fr 45fr;
  gap: 4rem;
  padding: 1rem 0;
}
.hfp__skeleton-image,
.hfp__sk-line {
  background: linear-gradient(90deg,#f0f0f0 25%,#e0e0e0 50%,#f0f0f0 75%);
  background-size: 200% 100%;
  animation: hfp-shimmer 1.6s linear infinite;
  border-radius: .6rem;
}
.hfp__skeleton-image {
  aspect-ratio: 1 / 1;
  border-radius: 1rem;
}
.hfp__skeleton-body { padding: 1rem 0; }
.hfp__sk-line      { display: block; }

/* ── footer CTA ── */
.hfp__footer       { text-align: center; margin-top: 2.5rem; }
.hfp__view-btn {
  display: inline-flex;
  align-items: center;
  gap: .6rem;
  padding: 1rem 2.8rem;
  border: 2px solid currentColor;
  border-radius: .6rem;
  font-weight: 600;
  font-size: 1.3rem;
  text-decoration: none;
  transition: background .2s, color .2s;
}
.hfp__view-btn:hover .hfp__view-btn-arrow { transform: translateX(4px); }
.hfp__view-btn-arrow                       { transition: transform .2s; }

/* ── editor placeholder ── */
.hfp__placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.2rem;
  padding: 5rem 2rem;
  border: 2px dashed #ccc;
  border-radius: 1.2rem;
  color: #999;
  text-align: center;
}
.hfp__placeholder p { margin: 0; font-size: 1.3rem; }

/* ── responsive ── */
@media (max-width: 768px) {
  .hfp__skeleton { grid-template-columns: 1fr; gap: 2rem; }
  .hfp__title    { font-size: 1.8rem; }
  .hfp__wrap     { min-height: 28rem; }
}
</style>

{% schema %}
{
  "name": "Featured Product",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "product",
      "id": "featured_product",
      "label": "Product",
      "info": "The product will be displayed in the same quick-view layout used on product pages."
    },
    {
      "type": "header",
      "content": "Section heading"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Eyebrow / subtitle",
      "default": "OUR BESTSELLER"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Featured Product"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "checkbox",
      "id": "show_view_btn",
      "label": "Show 'View Full Product' button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_btn_text",
      "label": "Button label",
      "default": "View Full Product Page"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Container width",
      "default": "box",
      "options": [
        { "value": "box",       "label": "Boxed"      },
        { "value": "wide",      "label": "Wide"       },
        { "value": "fullwidth", "label": "Full width" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme"
    },
    {
      "type": "select",
      "id": "background_type",
      "label": "Background type",
      "default": "color",
      "options": [
        { "value": "color",    "label": "Color"    },
        { "value": "gradient", "label": "Gradient" },
        { "value": "image",    "label": "Image"    }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "alpha": true,
      "visible_if": "{{ section.settings.background_type == 'color' }}"
    },
    {
      "type": "color_background",
      "id": "background_gradient",
      "label": "Background gradient",
      "visible_if": "{{ section.settings.background_type == 'gradient' }}"
    },
    {
      "type": "image_picker",
      "id": "background_image_desktop",
      "label": "Background image",
      "visible_if": "{{ section.settings.background_type == 'image' }}"
    },
    {
      "type": "number",
      "id": "padding_top",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "number",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Featured Product"
    }
  ]
}
{% endschema %}
