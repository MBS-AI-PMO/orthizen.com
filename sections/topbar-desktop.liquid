<div
  class='topbar-desktop'
  style='background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }}; font-size: {{ section.settings.font_size }}px; font-weight: {{ section.settings.font_weight }}; min-height: {{ section.settings.height }}px; padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;'
>
  <xo-container>
    <div class='topbar-desktop__grid topbar-desktop__grid--cols-{{ section.settings.columns }}'>
      {% for i in (1..3) %}
        {% assign col_key = 'col_' | append: i | append: '_text' %}
        {% assign col_text = section.settings[col_key] %}
        {% if col_text != blank %}
          <div class='topbar-desktop__col{% if section.settings.hide_last_column_tablet and forloop.last %} topbar-desktop__col--hide-tablet{% endif %}'>
            {{ col_text }}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </xo-container>
</div>

<style>
  .topbar-desktop {
    width: 100%;
    box-sizing: border-box;
    display: flex;
    align-items: center;
    position: relative;
    z-index: 199;
  }
  .topbar-desktop__grid {
    display: grid;
    align-items: center;
    width: 100%;
    gap: 12px;
  }
  .topbar-desktop__grid--cols-1 { grid-template-columns: 1fr; }
  .topbar-desktop__grid--cols-2 { grid-template-columns: repeat(2, 1fr); }
  .topbar-desktop__grid--cols-3 { grid-template-columns: repeat(3, 1fr); }
  .topbar-desktop__col { text-align: center; line-height: 1.4; }
  .topbar-desktop__col strong { font-weight: 700; }

  @media (max-width: 767px) {
    .topbar-desktop { display: none !important; }
  }
  @media (max-width: 992px) {
    .topbar-desktop__col--hide-tablet { display: none; }
    .topbar-desktop__grid--cols-3 { grid-template-columns: repeat(2, 1fr); }
  }
</style>

{% schema %}
{
  "name": "Topbar Desktop",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#1364b0"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "font_weight",
      "label": "Font weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "default": 700
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "height",
      "label": "Min height",
      "min": 30,
      "max": 80,
      "step": 5,
      "unit": "px",
      "default": 45
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "default": 3
    },
    {
      "type": "textarea",
      "id": "col_1_text",
      "label": "Column 1 text",
      "default": "CLEARANCE SALE: 70% OFF SITEWIDE"
    },
    {
      "type": "textarea",
      "id": "col_2_text",
      "label": "Column 2 text",
      "default": "👟 Try It Out: 45-Day Wear Guarantee"
    },
    {
      "type": "textarea",
      "id": "col_3_text",
      "label": "Column 3 text",
      "default": "⭐ 4.9 / 5.0 Based on 17,920+ Reviews"
    },
    {
      "type": "checkbox",
      "id": "hide_last_column_tablet",
      "label": "Hide last column on tablet",
      "default": true
    }
  ],
  "presets": [{ "name": "Topbar Desktop" }]
}
{% endschema %}
