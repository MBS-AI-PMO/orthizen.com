

{% liquid
  if section.settings.padding_top != null
    assign padding_top = '--pt: ' | append: section.settings.padding_top | append: ';'
  endif
  if section.settings.padding_bottom != null
    assign padding_bottom = '--pb: ' | append: section.settings.padding_bottom | append: ';'
  endif
%}

<section style='{{- padding_top -}} {{- padding_bottom }}' class='slideshow-v21'>
  <xo-animate xo-cascade>
    <xo-carousel
      xo-type='none'
      {% if section.settings.autoplay %}
        xo-autoplay='{{ section.settings.speed | times: 1000 }}'
      {% endif %}
      xo-speed='400'
      xo-loop
      xo-hover-pause
    >
      <xo-carousel-inner>
        <xo-carousel-list role='list' aria-label='{{ 'general.slider.name' | t }}'>
          {% for block in section.blocks %}
            <xo-carousel-slide aria-roledescription='{{ 'sections.slideshow.slide' | t }}' aria-label='{{ forloop.index }} {{ 'general.slider.of' | t }} {{ forloop.length }}'>
              <div class='slideshow-v21__slide {%- if block.settings.color_scheme %} color-{{ block.settings.color_scheme }}{% endif %}'>
                {% if block.settings.video != blank %}
                  <xo-video-cover
                    xo-src='{{ block.settings.video }}'
                    class='slideshow-v21__video'
                  ></xo-video-cover>
                {% elsif block.settings.background_image_desktop != blank or block.settings.background_image_mobile != blank %}
                  <xo-animate
                    xo-type='zoom-out'
                    xo-order='1'
                    xo-duration='1000'
                    class='slideshow-v21__bg-container'
                  >
                    {% if block.settings.background_image_desktop != blank %}
                      <div
                        class='xo-background-lazyload slideshow-v21__bg slideshow-v21__bg--desktop'
                        style='background-image: url("{{ block.settings.background_image_desktop | image_url: width: 100 }}")'
                      ></div>
                    {% endif %}
                    {% if block.settings.background_image_mobile != blank %}
                      <div
                        class='xo-background-lazyload slideshow-v21__bg slideshow-v21__bg--mobile'
                        style='background-image: url("{{ block.settings.background_image_mobile | image_url: width: 100 }}")'
                      ></div>
                    {% endif %}
                  </xo-animate>
                {% endif %}
                <div class='slideshow-v21__bg-color' style='background-color:{{block.settings.background_color}};background-image:{{block.settings.background_gradient}}'></div>
                <xo-container {% render 'section-layout' %}>
                  <xo-grid style='position: relative'>
                    {% if block.settings.reverse_layout == false %}
                      {% assign start_column = 2 %}
                    {% else %}
                      {% assign start_column = 8 %}
                    {% endif %}
                    <div style='--xs: 12; --md: 4; --start-md:{{start_column}}' class='slideshow-v21__text'>
                      <xo-animate xo-type='{{block.settings.title_animation}}' xo-order='1' xo-duration='700'>
                        <h2 class='slideshow-v21__title' style='--fontsize:{{block.settings.title_font_size | remove: "rem" }}; --fontweight:{{block.settings.title_font_weight}}'>
                          {{ block.settings.title }}
                        </h2>
                      </xo-animate>
                      <xo-animate xo-type='{{block.settings.description_animation}}' xo-order='3' xo-duration='700' xo-strength='3'>
                        <h3
                          class='slideshow-v21__description'
                          style='--fontsize:{{block.settings.description_font_size | remove: "rem" }}; --fontweight:{{block.settings.description_font_weight}}'
                        >
                          {{ block.settings.description }}
                        </h3>
                      </xo-animate>
                      <xo-animate xo-type='{{block.settings.button_animation}}' xo-order='6' xo-duration='700' xo-strength='3'>
                        {% render 'button',
                          text: block.settings.button_text,
                          link: block.settings.button_link,
                          mode: block.settings.button_mode,
                          style: block.settings.button_style,
                          size: block.settings.button_size,
                          radius: block.settings.button_radius,
                          padding: block.settings.button_padding
                        %}
                      </xo-animate>
                    </div>
                    <div class='slideshow-v21__arrows'>
                      <xo-carousel-prev class='slideshow-v21__arrow-btn'
                        ><button>{% render 'icon', name: 'arrow-left' %}</button></xo-carousel-prev
                      >
                      <xo-carousel-next class='slideshow-v21__arrow-btn'
                        ><button>{% render 'icon', name: 'arrow-right' %}</button></xo-carousel-next
                      >
                    </div>
                  </xo-grid>
                </xo-container>
              </div>
            </xo-carousel-slide>
          {% endfor %}
        </xo-carousel-list>
      </xo-carousel-inner>
    </xo-carousel>
  </xo-animate>
</section>

