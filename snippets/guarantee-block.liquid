{%- liquid
  assign gi = 'guarantee-' | append: block.id
-%}

<div class="{{ gi }}"
     style="
       --g-row-gap: {{ block.settings.item_gap }}px;
       --g-row-gap-mobile: {{ block.settings.item_gap_mobile }}px;
       --g-content-gap: {{ block.settings.icon_text_gap }}px;
       padding-top: {{ block.settings.padding_top }}px;
       padding-bottom: {{ block.settings.padding_bottom }}px;
     ">

  {%- for i in (1..4) -%}
    {%- liquid
      assign img_key  = 'item' | append: i | append: '_image'
      assign head_key = 'item' | append: i | append: '_heading'
      assign sub_key  = 'item' | append: i | append: '_subtext'
    -%}
    {%- if block.settings[head_key] != blank -%}
      <div class="{{ gi }}__item">
        <div class="{{ gi }}__icon">
          {%- if block.settings[img_key] -%}
            <img
              src="{{ block.settings[img_key] | image_url: width: 80 }}"
              alt="{{ block.settings[head_key] }}"
              loading="lazy"
              width="{{ block.settings.icon_size }}"
              height="{{ block.settings.icon_size }}"
            />
          {%- endif -%}
        </div>
        <div class="{{ gi }}__content">
          <h3 class="{{ gi }}__heading">{{ block.settings[head_key] }}</h3>
          {%- if block.settings[sub_key] != blank -%}
            <p class="{{ gi }}__subtext">{{ block.settings[sub_key] }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
  {%- endfor -%}

</div>

<style>
  .{{ gi }} {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--g-row-gap);
  }
  .{{ gi }}__item {
    display: flex;
    align-items: flex-start;
    gap: var(--g-content-gap);
  }
  .{{ gi }}__icon {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    min-width: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .{{ gi }}__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .{{ gi }}__content {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding-top: 2px;
  }
  .{{ gi }}__heading {
    margin: 0;
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    color: {{ block.settings.heading_color }};
    line-height: 1.3;
  }
  .{{ gi }}__subtext {
    margin: 0;
    font-size: {{ block.settings.subtext_font_size }}px;
    color: {{ block.settings.subtext_color }};
    line-height: 1.5;
    font-weight: 400;
  }
  @media (max-width: 768px) {
    .{{ gi }} {
      gap: var(--g-row-gap-mobile);
    }
    .{{ gi }}__icon {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
      min-width: {{ block.settings.icon_size_mobile }}px;
    }
    .{{ gi }}__heading {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }
    .{{ gi }}__subtext {
      font-size: {{ block.settings.subtext_font_size_mobile }}px;
    }
  }
</style>
