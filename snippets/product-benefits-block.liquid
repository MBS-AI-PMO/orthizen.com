<div class="benefits-container" style="padding-top: {{ block.settings.padding_top }}px; padding-bottom: {{ block.settings.padding_bottom }}px;">

  <div class="benefit-item">
    <div class="benefit-icon">
      {% if block.settings.benefit1_icon %}
        {{ block.settings.benefit1_icon | safe }}
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
          <path d="M30 50 Q30 30 50 20 Q70 30 70 50 Q70 75 50 85 Q30 75 30 50" stroke="#000" stroke-width="2.5" fill="none"></path>
          <circle cx="50" cy="50" r="8" fill="#000"></circle>
        </svg>
      {% endif %}
    </div>
    <p class="benefit-text">{{ block.settings.benefit1_text }}</p>
  </div>

  <div class="benefit-item">
    <div class="benefit-icon">
      {% if block.settings.benefit2_icon %}
        {{ block.settings.benefit2_icon | safe }}
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
          <path d="M50 15 L65 35 L50 45 L65 55 L50 65 Q35 75 25 85 Q20 80 20 70 Q20 60 30 50 Q20 45 20 35 Q20 25 25 20 Q35 25 50 35 Z" stroke="#000" stroke-width="2.5" fill="none"></path>
          <circle cx="50" cy="50" r="25" stroke="#000" stroke-width="2.5" fill="none"></circle>
        </svg>
      {% endif %}
    </div>
    <p class="benefit-text">{{ block.settings.benefit2_text }}</p>
  </div>

  <div class="benefit-item">
    <div class="benefit-icon">
      {% if block.settings.benefit3_icon %}
        {{ block.settings.benefit3_icon | safe }}
      {% else %}
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
          <path d="M15 55 L20 50 L30 60 L50 35 L60 45" stroke="#000" stroke-width="2.5" fill="none" stroke-linecap="round"></path>
          <rect x="25" y="65" width="50" height="20" stroke="#000" stroke-width="2" fill="none"></rect>
          <circle cx="35" cy="85" r="4" fill="#000"></circle>
          <circle cx="65" cy="85" r="4" fill="#000"></circle>
        </svg>
      {% endif %}
    </div>
    <p class="benefit-text">{{ block.settings.benefit3_text }}</p>
  </div>

</div>

<style>
  .benefits-container {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_gap }}px;
    padding-top: {{ block.settings.padding_top }}px;
    padding-bottom: {{ block.settings.padding_bottom }}px;
  }

  .benefit-item {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 15px;
  }

  .benefit-icon {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    min-width: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .benefit-icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .benefit-text {
    font-size: {{ block.settings.text_font_size }}rem;
    line-height: 1.5;
    color: #555;
    margin: 0;
    font-weight: 400;
    text-align: left;
  }

  /* Desktop */
  @media (min-width: 769px) {
    .benefit-item {
      align-items: center;
    }
  }

  /* Tablet/Mobile */
  @media (max-width: 768px) {
    .benefit-item {
      gap: 12px;
      align-items: flex-start;
    }

    .benefit-text {
      font-size: {{ block.settings.text_font_size | minus: 0.15 }}rem;
    }
  }

  @media (max-width: 480px) {
    .benefit-item {
      gap: 10px;
    }

    .benefit-icon {
      width: {{ block.settings.icon_size | minus: 10 }}px;
      height: {{ block.settings.icon_size | minus: 10 }}px;
      min-width: {{ block.settings.icon_size | minus: 10 }}px;
    }

    .benefit-text {
      font-size: {{ block.settings.text_font_size | minus: 0.25 }}rem;
    }
  }
</style>
