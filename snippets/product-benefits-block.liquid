<div class="product-benefits__item" {{ block.shopify_attributes }} style='--icon-size: {{ block.settings.icon_size | default: 32 }}px; --text-font-size: {{ block.settings.text_font_size | default: 1.6 }}rem; --icon-text-gap: {{ block.settings.icon_text_gap | default: 10 }}px; padding-top:{{ block.settings.padding_top | append: 'px' }}; padding-bottom:{{ block.settings.padding_bottom | append: 'px'}}'>
  {% if block.settings.icon_type == 'svg' and block.settings.icon_svg != blank %}
    <div class="product-benefits__icon">
      {{ block.settings.icon_svg }}
    </div>
  {% elsif block.settings.icon_type == 'image' and block.settings.icon_image %}
    <div class="product-benefits__icon product-benefits__icon--image">
      {% render 'image', image: block.settings.icon_image, alt: block.settings.text %}
    </div>
  {% endif %}

  <p class="product-benefits__text">{{ block.settings.text }}</p>
</div>

<style>
  .product-benefits__container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
    align-items: start;
    width: 100%;
    padding: 20px 0;
  }

  .product-benefits__item {
    display: flex;
    flex-direction: row;
    align-items: center;
    text-align: left;
    gap: var(--icon-text-gap, 10px);
  }

  .product-benefits__icon {
    width: var(--icon-size, 32px);
    height: var(--icon-size, 32px);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-right: 0;
  }

  .product-benefits__icon svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    color: #666;
  }

  .product-benefits__icon--image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .product-benefits__text {
    font-size: var(--text-font-size, 1.6rem);
    line-height: 1.4;
    color: #666;
    margin: 0;
    font-weight: 400;
  }

  @media (max-width: 1024px) {
    .product-benefits__container {
      grid-template-columns: 1fr;
      gap: 20px;
    }
  }

  @media (max-width: 768px) {
    .product-benefits__container {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 15px 0;
    }

    .product-benefits__item {
      flex-direction: row;
      text-align: left;
      gap: var(--icon-text-gap, 10px);
      align-items: center;
    }

    .product-benefits__icon {
      width: calc(var(--icon-size, 32px) * 0.85);
      height: calc(var(--icon-size, 32px) * 0.85);
      min-width: calc(var(--icon-size, 32px) * 0.85);
    }

    .product-benefits__text {
      font-size: calc(var(--text-font-size, 1.6rem) * 0.9);
    }
  }
</style>
